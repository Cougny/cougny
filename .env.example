# ---------------------------------------------------------------------------
# Cougny local environment. Copy to `.env` and adjust as needed.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# --- Shared ---
NODE_ENV=development

# --- Postgres (packages/db, apps/api) ---
POSTGRES_USER=cougny
POSTGRES_PASSWORD=cougny
POSTGRES_DB=cougny
DATABASE_URL=postgresql://cougny:cougny@localhost:5432/cougny?schema=public

# --- Redis (matchmaking presence / scale-out, optional in dev) ---
REDIS_URL=redis://localhost:6379

# --- API service (apps/api) ---
API_HOST=0.0.0.0
API_PORT=4000
# Secret used to sign short-lived session/auth tokens.
AUTH_JWT_SECRET=dev-change-me-in-production

# --- Signaling service (apps/signaling) ---
SIGNALING_HOST=0.0.0.0
SIGNALING_PORT=4001
# Comma-separated list of browser origins allowed to open a socket.
SIGNALING_ALLOWED_ORIGINS=http://localhost:3000

# --- WebRTC ICE (coturn) ---
# STUN is public; TURN uses coturn's REST-API (use-auth-secret) shared secret.
# The API mints ephemeral HMAC credentials from this secret — clients never see it.
STUN_URL=stun:localhost:3478
TURN_URL=turn:localhost:3478
TURN_STATIC_AUTH_SECRET=dev-turn-shared-secret-change-me
# TTL (seconds) for a minted TURN credential.
TURN_CREDENTIAL_TTL=86400

# --- Web app (apps/web) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SIGNALING_URL=ws://localhost:4001
