# Dependencies and build output are reinstalled/rebuilt inside the image.
**/node_modules
**/dist
**/.next
**/.turbo
**/*.tsbuildinfo
.pnpm-store

# VCS / CI / editor
.git
.github
.husky
.vscode
.idea

# Env and secrets (pass real values at runtime). Globbed so per-app files
# (apps/*/.env, packages/*/.env) are excluded too, while examples are kept.
**/.env
**/.env.*
!**/.env.example

# Local infra / docs / misc
infra/**/data
coverage
*.log
.DS_Store
