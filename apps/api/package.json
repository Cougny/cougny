    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "prom-client": "^15.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cougny/config-eslint": "workspace:*",
    "@cougny/config-typescript": "workspace:*",
    "@types/jsonwebtoken": "^9.0.10",
