# apps/api — API service environment.
#   cp .env.example .env
# Real environment variables always win over this file.

NODE_ENV=development

# --- HTTP server ---
API_HOST=0.0.0.0
API_PORT=4000

# --- Database (Prisma via @cougny/db) ---
DATABASE_URL=postgresql://cougny:cougny@localhost:5432/cougny?schema=public

# --- Auth ---
# Secret used to sign short-lived session/auth tokens (min 16 chars).
AUTH_JWT_SECRET=dev-change-me-in-production

# --- CORS ---
# Comma-separated list of browser origins allowed to call the API.
SIGNALING_ALLOWED_ORIGINS=http://localhost:3000

# --- WebRTC ICE (coturn) ---
# STUN is public; TURN uses coturn's REST-API (use-auth-secret) shared secret.
# The API mints ephemeral HMAC credentials from this secret — clients never see it.
STUN_URL=stun:localhost:3478
TURN_URL=turn:localhost:3478
TURN_STATIC_AUTH_SECRET=dev-turn-shared-secret-change-me
# TTL (seconds) for a minted TURN credential.
TURN_CREDENTIAL_TTL=86400
