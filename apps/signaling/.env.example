# apps/signaling — signaling service environment.
#   cp .env.example .env
# Real environment variables always win over this file.

NODE_ENV=development

SIGNALING_HOST=0.0.0.0
SIGNALING_PORT=4001
# Comma-separated list of browser origins allowed to open a socket.
SIGNALING_ALLOWED_ORIGINS=http://localhost:3000
# Max peers waiting to be matched at once; further joins are shed (backpressure).
SIGNALING_MAX_QUEUE=10000

# --- Auth ---
# Must match the API's AUTH_JWT_SECRET: session tokens minted by the API are
# verified here at the WebSocket handshake.
AUTH_JWT_SECRET=dev-change-me-in-production

# --- Database (Prisma via @cougny/db) ---
# Call records are written on match/end so reports can be validated.
DATABASE_URL=postgresql://cougny:cougny@localhost:5432/cougny?schema=public
